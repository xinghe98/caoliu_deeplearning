# Copy to .env before docker compose (deploy.sh does this for you).
# Paths below are INSIDE the container. Host paths are set via compose variables
# PLATFORM_DATA_HOST / MODEL_HOST_DIR / MEDIA_HOST_DIR (see deploy.sh).

# --- runtime data ---
PLATFORM_DATA_DIR=/data/platform_data
# DATABASE_URL=sqlite:////data/platform_data/platform.db

# Media roots visible to the app (semicolon-separated). Default single mount:
ALLOWED_MEDIA_ROOTS=/data/media

# Crawler ingest key (MUST be long random; share with caoliuSpider)
INGEST_API_KEY=replace-with-a-long-random-value

# Default checkpoint when no model is manually activated
DEFAULT_MODEL_PATH=/data/models/best_model.pth
DEFAULT_MODEL_VERSION=default-env

# Product knobs
FEED_RECOMMENDATION_RATIO=0.8
TRAINING_LABEL_THRESHOLD=200
SKIP_COOLDOWN_DAYS=7

# Security (LAN HTTP: false; reverse-proxy HTTPS: true)
COOKIE_SECURE=false
CSRF_ENABLED=true
AUTO_CREATE_TABLES=true

# Candidate upload limits
CANDIDATE_MAX_UPLOAD_MB=512
CANDIDATE_MAX_FILES=200
CANDIDATE_MAX_UNCOMPRESSED_MB=1024

# Login rate limit
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# Compose-only (read by docker-compose.yml / deploy.sh, not all used by app)
HOST_PORT=8080
WORKER_BATCH_SIZE=8
WORKER_POLL_SECONDS=5
